# AionX Environment Configuration
# Copy this file to .env and fill in the values

# App identity
VITE_APP_NAME=AionX
VITE_APP_VERSION=1.0.0

# External URLs (used in About page buttons)
VITE_GITHUB_URL=https://github.com/your-org/aionx
VITE_DOCS_URL=https://your-docs-site.com

# Auto-updater feed URL (e.g. GitHub Releases or S3 bucket)
# Leave blank to disable auto-updates
VITE_UPDATE_FEED_URL=

# Show DevTools in dev mode
VITE_ENABLE_DEVTOOLS=true

# ── Sentry — crash reporting ──────────────────────────────────────────────────
# 1. Create a project at https://sentry.io
# 2. Go to: Settings → Projects → [your project] → Client Keys (DSN)
# 3. Paste the DSN here
VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o0000000.ingest.sentry.io/0000000

# Set to "true" to test Sentry in development mode (off by default)
VITE_SENTRY_FORCE=false

# ── PostHog — product analytics ───────────────────────────────────────────────
# 1. Create a project at https://app.posthog.com
# 2. Go to: Project Settings → Project API Key
# 3. Paste the key here (starts with phc_)
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Self-hosted PostHog? Change this to your instance URL
VITE_POSTHOG_HOST=https://app.posthog.com

# ── Firebase — auth + data backend ────────────────────────────────────────────
# From: Firebase Console → Project settings → General → Your apps → SDK setup and config
VITE_FIREBASE_API_KEY=AIzaSyCdnPY6cy8gu4CNB8RTmh5Ss1uAhxayFjM
VITE_FIREBASE_AUTH_DOMAIN=lcms-f185e.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=lcms-f185e
VITE_FIREBASE_STORAGE_BUCKET=lcms-f185e.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=679360908927
VITE_FIREBASE_APP_ID=1:679360908927:web:6f68db231f930775c1f94a
